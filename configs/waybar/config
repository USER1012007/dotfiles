{
    "layer": "top",
    "height": 32,
    "margin-top": 4,
    "margin-left": 4,
    "margin-right": 4,
    "spacing": 0, 

    // Módulos organizados de manera limpia
    "modules-left": [
        "network", 
        "wlr/taskbar"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "keyboard-state", 
        "pulseaudio", 
        "battery"
    ],

    "wlr/taskbar": {
        "format": "{icon}",
        "tooltip-format": "{title} | {app_id}",
        "on-click-middle": "close",
        "on-click-right": "fullscreen"
    },

    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "",
            "unlocked": ""
        }
    },

    // "clock": {
    //     "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    //     "format": "{:%e %B %I:%M %p}"
    // },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%e %B %I:%M %p}",
        "on-click": "gsimplecal",
        "tooltip": false
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% 󱐋", /* Icono Nerdfont más moderno para carga */
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        "format-icons": ["", "", "", "", ""]
    },

    "network": {
        "format-wifi": " ",
        "format-ethernet": "󰈀", /* Icono Nerdfont actualizado */
        "tooltip-format": "{ifname} via {gwaddr} ",
        "format-linked": "",
        "format-disconnected": "󰖪", /* Ícono sutil sin advertencias chillonas */
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },

    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}",
        "format-bluetooth-muted": "󰝟 {icon}",
        "format-muted": "󰝟", /* Icono de muteo más limpio */
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["󰕿", "󰖀", "󰕾"] /* Iconos de volumen Nerdfont fluidos */
        },
        "on-click": "pwvucontrol"
    }
}
